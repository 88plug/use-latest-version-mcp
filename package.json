{
  "name": "use-latest-version-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that provides latest package versions from multiple registries",
  "type": "module",
  "bin": {
    "use-latest-version-mcp-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc && node build/index.js stdio",
    "dev:http": "tsc && node build/index.js http",
    "start": "node build/index.js http",
    "prepare": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "ai-agents",
    "developer-tools",
    "productivity",
    "automation",
    "cli",
    "claude-code-plugin",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "package-versions",
    "dependencies",
    "npm",
    "registries",
    "outdated",
    "semver"
  ],
  "author": "88plug <andrew@88plug.com>",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/88plug/use-latest-version-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/88plug/use-latest-version-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/88plug/use-latest-version-mcp/issues"
  },
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3"
  }
}
